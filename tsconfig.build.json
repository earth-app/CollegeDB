{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"emitDeclarationOnly": true,
		"declaration": true,
		"declarationMap": true,
		"rootDir": "src",
		"outDir": "dist",
		"allowImportingTsExtensions": false,
		"verbatimModuleSyntax": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules", "coverage", "typedoc", "examples", "sandbox", "scripts", "demos", "**/*.test.ts", "**/*.spec.ts"]
}
